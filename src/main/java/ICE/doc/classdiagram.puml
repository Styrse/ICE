@startuml
class Platform{
- String platformName
- ArrayList<Client> clients
- ArrayList<Server> servers
}

class Server{
- String serverName
- ArrayList<Client> clients
}

class Client{
- String id
- String username
- String password
- HashMap<Client, Message> privateMessages
- ArrayList<Server> servers
- boolean online
- ArrayList<Client> friends
- ArrayList<Client> blockedAccounts
- String IP
}

class Chatroom{
- String name
- ArrayList<Client> clients
- ArrayList<Message> messages
}

class Message{
- Client sender
- Client receiver
- String message
- Date date/time
- String IP
- String location
}

class Encrypting{
+ String encrypt(String message)
+ String decrypt(String message)
}

Platform *-- Server
Platform *-- Client

Client *-- Message

Server *-- Client
Server *-- Chatroom

package util{
class GUI
class API
class Encrypting
database Database{
}

}

@enduml